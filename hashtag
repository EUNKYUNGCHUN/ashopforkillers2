<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>킬러들의 쇼핑몰2 SNS 이벤트</title>

<meta property="og:title" content="킬러들의 쇼핑몰2 SNS 이벤트">
<meta property="og:description" content="해시태그 복사 후 SNS 업로드">
<meta property="og:image" content="./poster.jpg">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#000;
    font-family:Pretendard,sans-serif;
}

.container{
    position:relative;
    max-width:828px;
    margin:0 auto;
}

.poster{
    width:100%;
    display:block;
}

.copy-btn{
    position:absolute;
    left:50%;
    bottom:16.8%;
    transform:translateX(-50%);
    width:52%;
    height:5%;
    border:none;
    background:transparent;
    cursor:pointer;
}

.toast{
    position:fixed;
    left:50%;
    bottom:30px;
    transform:translateX(-50%);
    background:#E60012;
    color:#fff;
    padding:14px 24px;
    border-radius:999px;
    font-size:16px;
    font-weight:700;
    opacity:0;
    transition:.3s;
}

.toast.show{
    opacity:1;
}
</style>
</head>

<body>

<div class="container">

    poster.jpg 쇼핑몰2 SNS 이벤트"
        class="poster"
    >

    <button
        class="copy-btn"
        onclick="copyHashtag()"
        aria-label="해시태그 복사하기">
    </button>

</div>

<div id="toast" class="toast">
복사되었습니다!
</div>

<script>
function copyHashtag(){

const hashtags = `#킬러들의쇼핑몰2
#머더헬프강남점오픈
#디즈니플러스
@disneypluskr`;

navigator.clipboard.writeText(hashtags);

const toast = document.getElementById('toast');

toast.classList.add('show');

setTimeout(() => {
toast.classList.remove('show');
}, 2000);

}
</script>

</body>
</html>
