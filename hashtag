<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<meta property="og:title" content="킬러들의 쇼핑몰2">
<meta property="og:description" content="해시태그 복사하기">
<meta property="og:image" content="./og-image.jpg">
<meta property="og:type" content="website">

<title>킬러들의 쇼핑몰2</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    width:100%;
    min-height:100vh;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    background:#000;
    color:#fff;
    overflow:hidden;
}

/* 배경 */
.background{
    position:fixed;
    inset:0;
    background:url('./background.jpg') center center / cover no-repeat;
}

.overlay{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.45);
}

/* 컨텐츠 */
.container{
    position:relative;
    z-index:10;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    padding:24px;
    text-align:center;
}

.logo{
    max-width:420px;
    width:90%;
    margin-bottom:40px;
}

/* 버튼 */
.copy-btn{
    width:100%;
    max-width:340px;
    border:none;
    cursor:pointer;
    padding:18px 24px;
    border-radius:999px;
    font-size:18px;
    font-weight:700;
    color:#fff;
    background:#111;
    backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,.15);
    transition:.2s;
}

.copy-btn:hover{
    transform:translateY(-2px);
}

.copy-btn:active{
    transform:scale(.98);
}

/* 토스트 */
.toast{
    position:fixed;
    left:50%;
    bottom:40px;
    transform:translateX(-50%);
    background:#111;
    color:#fff;
    padding:14px 20px;
    border-radius:12px;
    opacity:0;
    visibility:hidden;
    transition:.3s;
    z-index:100;
}

.toast.active{
    opacity:1;
    visibility:visible;
}

/* 하단 안내 */
.desc{
    margin-top:20px;
    font-size:14px;
    opacity:.8;
}
</style>
</head>

<body>

<div class="background"></div>
<div class="overlay"></div>

<div class="container">

    <!-- 로고 이미지 -->
    <!-- 디자인 들어오면 교체 -->
    <!-- ./logo.png -->

    <button class="copy-btn" onclick="copyTags()">
        해시태그 복사하기
    </button>

    <div class="desc">
        SNS 업로드 시 해시태그를 사용해 주세요
    </div>

</div>

<div id="toast" class="toast">
    ✅ 해시태그가 복사되었습니다.
</div>

<script>
function copyTags() {

    const text = `#킬러들의쇼핑몰2
#머더헬프강남점오픈
#디즈니플러스
@disneypluskr`;

    navigator.clipboard.writeText(text)
    .then(() => {
        const toast = document.getElementById('toast');

        toast.classList.add('active');

        setTimeout(() => {
            toast.classList.remove('active');
        }, 2000);
    })
    .catch(() => {
        alert('복사에 실패했습니다.');
    });
}
</script>

</body>
</html>
